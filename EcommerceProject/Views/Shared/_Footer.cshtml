<footer class="main-footer">
    <div class="container footer-grid">

        <div class="footer-brand-box">
            <a asp-controller="Home" asp-action="Index" class="footer-logo">
                <img src="~/images/logo.png" alt="SHOPORA Logo" class="footer-brand-img" />
                <span class="footer-brand-name">SHOPORA</span>
            </a>

            <p>
                Best information about the company goes here. Shop latest products with secure and easy shopping experience.
            </p>

            <div class="social-icons">
                <a href="#"><i class="bi bi-facebook"></i></a>
                <a href="#"><i class="bi bi-twitter-x"></i></a>
                <a href="#"><i class="bi bi-linkedin"></i></a>
                <a href="#"><i class="bi bi-instagram"></i></a>
            </div>
        </div>

        <div>
            <h4>About</h4>
            <a href="#">About Us</a>
            <a href="#">Find store</a>
            <a href="#">Categories</a>
            <a href="#">Blogs</a>
        </div>

        <div>
            <h4>Partnership</h4>
            <a href="#">About Us</a>
            <a href="#">Find store</a>
            <a href="#">Categories</a>
            <a href="#">Blogs</a>
        </div>

        <div>
            <h4>Information</h4>
            <a href="#">Help Center</a>
            <a href="#">Money Refund</a>
            <a href="#">Shipping</a>
            <a href="#">Contact us</a>
        </div>

        <div>
            <h4>For users</h4>
            <a asp-area="Identity" asp-page="/Account/Login">Login</a>
            <a asp-area="Identity" asp-page="/Account/Register">Register</a>
            <a asp-controller="CartItems" asp-action="Index">My Cart</a>
            <a href="#">My Orders</a>
        </div>

    </div>

    <div class="footer-bottom">
        <div class="container footer-bottom-flex">
            <p>© 2025 SHOPORA. All rights reserved.</p>
            <p>English</p>
        </div>
    </div>
</footer>
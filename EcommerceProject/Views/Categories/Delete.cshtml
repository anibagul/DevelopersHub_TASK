@model EcommerceProject.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<section class="category-admin-page">
    <div class="container">

        <div class="category-page-header">
            <div>
                <p class="category-subtitle">Admin / Categories / Delete</p>
                <h1>Delete Category</h1>
            </div>

            <div class="category-header-actions">
                <a asp-controller="Categories" asp-action="Index" class="category-secondary-btn">
                    <i class="bi bi-arrow-left"></i>
                    Back to Categories
                </a>
            </div>
        </div>

        <div class="category-delete-card">

            <div class="category-delete-warning">
                <i class="bi bi-exclamation-triangle"></i>

                <div>
                    <h2>Are you sure you want to delete this category?</h2>
                    <p>
                        This action will remove the category from your database. If this category has products, delete or move those products first.
                    </p>
                </div>
            </div>

            <div asp-validation-summary="ModelOnly" class="validation-summary delete-validation"></div>

            <div class="category-delete-info">
                <div class="category-delete-icon">
                    <i class="bi bi-grid-3x3-gap-fill"></i>
                </div>

                <div>
                    <h3>@Model.Name</h3>
                    <p>Category ID: #@Model.Id</p>
                </div>
            </div>

            <form asp-controller="Categories" asp-action="Delete" method="post" class="category-delete-actions">
                @Html.AntiForgeryToken()

                <input type="hidden" asp-for="Id" />

                <button type="submit" class="category-delete-btn">
                    <i class="bi bi-trash"></i>
                    Yes, Delete
                </button>

                <a asp-controller="Categories" asp-action="Index" class="category-secondary-btn">
                    Cancel
                </a>
            </form>

        </div>

    </div>
</section>
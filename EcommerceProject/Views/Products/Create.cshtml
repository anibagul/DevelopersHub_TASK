@model EcommerceProject.Models.Product

@{
    ViewData["Title"] = "Add Product";
}

<section class="product-form-page">
    <div class="container">

        <div class="product-form-header">
            <div>
                <p class="product-form-subtitle">Admin / Products / Create</p>
                <h1>Add New Product</h1>
            </div>

            <div class="product-form-header-actions">
                <a asp-controller="Admin" asp-action="Index" class="product-secondary-btn">
                    <i class="bi bi-speedometer2"></i>
                    Dashboard
                </a>

                <a asp-controller="Products" asp-action="Index" class="product-secondary-btn">
                    <i class="bi bi-arrow-left"></i>
                    Back to Products
                </a>
            </div>
        </div>

        <div class="product-form-layout">

            <div class="product-form-card">
                <div class="product-form-card-header">
                    <h2>Product Information</h2>
                    <p>Fill product details. This product will be saved in database.</p>
                </div>

                <form asp-controller="Products" asp-action="Create" method="post" class="product-admin-form">
                    @Html.AntiForgeryToken()

                    <div asp-validation-summary="ModelOnly" class="validation-summary"></div>

                    <div class="form-group">
                        <label asp-for="Name">Product Name</label>
                        <input asp-for="Name" placeholder="Example: iPhone 14 Pro Max" />
                        <span asp-validation-for="Name" class="field-validation"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Description">Description</label>
                        <textarea asp-for="Description" placeholder="Write product description..."></textarea>
                        <span asp-validation-for="Description" class="field-validation"></span>
                    </div>

                    <div class="form-row">
                        <div class="form-group">
                            <label asp-for="Price">Price</label>
                            <input asp-for="Price" type="number" step="0.01" placeholder="0.00" />
                            <span asp-validation-for="Price" class="field-validation"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Stock">Stock</label>
                            <input asp-for="Stock" type="number" placeholder="0" />
                            <span asp-validation-for="Stock" class="field-validation"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label asp-for="CategoryId">Category</label>
                        <select asp-for="CategoryId" asp-items="ViewBag.CategoryId">
                            <option value="">-- Select Category --</option>
                        </select>
                        <span asp-validation-for="CategoryId" class="field-validation"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="ImageUrl">Image URL / Image Path</label>
                        <input asp-for="ImageUrl" placeholder="/images/products/phone.png" />
                        <span asp-validation-for="ImageUrl" class="field-validation"></span>

                        <small class="input-help">
                            Example: /images/products/phone.png
                        </small>
                    </div>

                    <div class="image-preview-box">
                        <p>Image Preview</p>
                        <div class="image-preview">
                            <img id="productImagePreview" src="/images/products/phone.png" alt="Product preview" />
                        </div>
                    </div>

                    <div class="form-actions">
                        <button type="submit" class="product-primary-btn">
                            <i class="bi bi-check-circle"></i>
                            Save Product
                        </button>

                        <a asp-controller="Products" asp-action="Index" class="product-cancel-btn">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>

            <aside class="product-help-card">
                <div class="help-icon">
                    <i class="bi bi-box-seam"></i>
                </div>

                <h3>Product Tips</h3>

                <p>
                    Add clear product names, correct prices, and proper image paths for a clean storefront.
                </p>

                <ul>
                    <li>Image path should start with <strong>/images/</strong>.</li>
                    <li>Stock cannot be negative.</li>
                    <li>Choose correct category.</li>
                    <li>Keep product description useful.</li>
                </ul>
            </aside>

        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const imageInput = document.getElementById("ImageUrl");
        const previewImage = document.getElementById("productImagePreview");

        if (imageInput && previewImage) {
            imageInput.addEventListener("input", function () {
                if (imageInput.value.trim() !== "") {
                    previewImage.src = imageInput.value;
                }
            });
        }
    </script>
}